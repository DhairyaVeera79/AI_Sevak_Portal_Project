# Keep mock mode until org integrations are approved.
DATA_SOURCE_MODE=mock

# For future org integration adapter mode:
# DATA_SOURCE_MODE=org

# PostgreSQL connection (Prisma)
# Generic format:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ai_sevak_portal"

# Supabase (recommended for current setup):
# Use pooled URI for runtime/client connections:
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use direct URI for Prisma migrations:
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-<REGION>.pooler.supabase.com:5432/postgres"
DATABASE_URL=""
DIRECT_URL=""
